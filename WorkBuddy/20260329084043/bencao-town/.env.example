# 本地开发环境变量示例
# 复制此文件为 .env.local 并填入实际值

# ==================== Supabase 配置 ====================
# 获取方式：Supabase Dashboard → Settings → API

# Supabase 项目 URL（公开，客户端访问）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（公开，客户端访问）
# ⚠️ 注意：此密钥有 RLS（Row Level Security）保护，相对安全
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase 服务角色密钥（仅服务端使用，绝不能暴露到客户端！）
# ⚠️ 警告：此密钥可以绕过 RLS，不要在客户端代码中使用
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==================== Gemini AI 配置（用于食物识别） ====================
# 获取方式：Google Cloud Console → AI Studio → 获取 API Key

# Google Gemini API Key（用于 AI 食物识别）
# ⚠️ 警告：仅在服务端使用，不要暴露到客户端代码
GEMINI_API_KEY=AIzaSy...

# ==================== 应用配置 ====================

# 应用运行环境（development/production）
NODE_ENV=development

# 应用 URL（用于 OAuth 回调等）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================== Cloudflare Pages 部署专用 ====================
# ⚠️ 注意：这些变量需要在 Cloudflare Pages 控制台设置，不要提交到代码仓库！

# 部署到 Cloudflare Pages 时，在 Pages 项目设置 → 环境变量 中添加：
# - NEXT_PUBLIC_SUPABASE_URL（公开）
# - NEXT_PUBLIC_SUPABASE_ANON_KEY（公开）
# - SUPABASE_SERVICE_ROLE_KEY（私有）
# - GEMINI_API_KEY（私有）
# - NODE_ENV=production

# ==================== 安全提示 ====================
#
# 1. NEXT_PUBLIC_ 前缀的变量会暴露到浏览器
#    ✅ 可公开：URL、匿名密钥（有 RLS 保护）
#    ❌ 绝不能公开：服务角色密钥、数据库密码、API 密钥
#
# 2. 不带 NEXT_PUBLIC_ 前缀的变量仅服务端可访问
#    ✅ 安全：服务角色密钥、数据库密码、API 密钥
#
# 3. 不要将 .env.local 文件提交到 Git
#    已在 .gitignore 中配置
#
# ==================== 本地开发快速开始 ====================
#
# 1. 安装依赖：npm install
# 2. 复制环境变量：cp .env.example .env.local
# 3. 填入 Supabase 和 Gemini 密钥
# 4. 启动开发服务器：npm run dev
# 5. 访问 http://localhost:3000
#
